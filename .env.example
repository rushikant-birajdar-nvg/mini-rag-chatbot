# Copy to .env and fill in the values. Do not commit .env.

# JWT signing secret for mock auth tokens
JWT_SECRET=please-change-me-to-a-long-random-string


# =============================================================================
# LLM PROVIDER — pick one. Free-tier options listed first.
# =============================================================================

# Groq — free tier, no credit card, very fast streaming
# Sign up at https://console.groq.com to get a key
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini — free tier on gemini-2.0-flash
# Sign up at https://aistudio.google.com to get a key
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash

# OpenRouter — has free-tier models
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Ollama — fully local, no API key needed (requires ollama installed)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# OpenAI — paid, optional
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic — paid, optional
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001


# =============================================================================
# EMBEDDINGS — free local model is fine
# =============================================================================

# Local (recommended — free, runs on CPU, downloads once)
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Or use OpenAI if you prefer
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small


# =============================================================================
# VECTOR DB
# =============================================================================

# Qdrant in Docker: docker run -p 6333:6333 qdrant/qdrant
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# Or Chroma in local/persistent mode
# CHROMA_PATH=./chroma_data
